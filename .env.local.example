# ---- Neon Postgres ----
# Connection string z Neon dashboardu (Connect → Connection string, pooled).
DATABASE_URL=postgresql://<user>:<password>@<host>.neon.tech/<db>?sslmode=require

# ---- Neon Auth (Stack Auth) ----
# Z Neon Console → Auth (nebo Stack Auth dashboardu). Project ID + klíče.
NEXT_PUBLIC_STACK_PROJECT_ID=<stack-project-id>
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=<stack-publishable-client-key>
STACK_SECRET_SERVER_KEY=<stack-secret-server-key>

# ---- Vercel Blob (úložiště fotek) ----
# Z Vercel → Storage → Blob → tokens (nebo se doplní automaticky přes Vercel integraci).
BLOB_READ_WRITE_TOKEN=<vercel-blob-rw-token>

# ---- App ----
# URL aplikace – lokálně http://localhost:3000, na produkci doména z Vercelu.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Volitelny allowlist e-mailu (osobni appka). Pokud nastaveno, jen tyto ucty maji pristup.
# ALLOWED_EMAILS=tvuj@email.cz,druhy@email.cz

# ---- Lokalni vyvoj bez Stack Auth (volitelne) ----
# Pokud nemas jeste Stack Auth klice, zapni dev bypass: appka pobezi s fake
# uzivatelem (bez prihlaseni). Funguje JEN v dev (NODE_ENV != production),
# v produkci se vzdy ignoruje. Pak staci jen DATABASE_URL.
# DEV_AUTH_BYPASS=1
# NEXT_PUBLIC_DEV_AUTH_BYPASS=1
